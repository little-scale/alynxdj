 static CSystem *lynx = NULL;
 
+/* ComLynx bridge exports (ALYNXDJ duo harness): plain-C entry points so a
+ * host can wire two core instances TX->RX for two-unit sync testing. */
+extern "C" {
+   void handy_comlynx_cable(int status)
+   {
+      if (lynx) lynx->ComLynxCable(status);
+   }
+   void handy_comlynx_rx(int data)
+   {
+      if (lynx) lynx->ComLynxRxData(data);
+   }
+   void handy_comlynx_set_tx(void (*cb)(int data, ULONG ref), ULONG ref)
+   {
+      if (lynx) lynx->ComLynxTxCallback(cb, ref);
+   }
+}
